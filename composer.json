{
    "name": "amin/cpl-coreguard",
    "type": "wordpress-plugin",
    "license": "GPLv2",
    "autoload": {
        "psr-4": {
            "Amin\\CPL_CoreGuard\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Al Amin",
            "email": "hmalaminmb4@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "require-dev": {
        "squizlabs/php_codesniffer": "3.x-dev",
        "wp-coding-standards/wpcs": "dev-develop",
        "phpcsstandards/phpcsutils": "^1.0@dev",
        "phpcsstandards/phpcsextra": "^1.0@dev",
        "phpunit/phpunit": "^9.0",
        "mockery/mockery": "^1.4",
        "mikey179/vfsstream": "^1.6"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.2"
        }
    }
}
